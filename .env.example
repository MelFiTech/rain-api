PORT=9090
NODE_ENV=development

# PostgreSQL (Neon or local). Prisma uses this.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# Generate: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRES_IN=24h

# Live institution app URL (links in emails). CORS allows any browser origin.
WEB_APP_URL=http://localhost:3000

PAYMENT_PROVIDER=monnify
WEBHOOK_DELIVERY_PROVIDER=http

# Monnify sandbox: https://sandbox.monnify.com
MONNIFY_API_KEY=MK_TEST_XXXXXX
MONNIFY_SECRET_KEY=SK_TEST_XXXXXX
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_WALLET_REDIRECT_URL=http://localhost:3000/wallet
MONNIFY_WALLET_ACCOUNT_NUMBER=

EMAIL_PROVIDER=console

# Optional (defaults are fine for local demo)
# EMAIL_FROM=Rain <noreply@rain.ng>
# MONNIFY_WEBHOOK_ENFORCE_IP=false
# EARNINGS_BANK_WITHDRAW_MIN_DELAY_MINUTES=0
# EARNINGS_BANK_WITHDRAW_MAX_DELAY_MINUTES=0
