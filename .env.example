# =============================================================================
# Rain API — copy to .env and fill in values (never commit .env)
# =============================================================================

# --- Server ---
PORT=9090
NODE_ENV=development

# --- Database (required) ---
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# --- Auth (required) ---
# Generate: openssl rand -hex 32
JWT_SECRET=change-me
JWT_EXPIRES_IN=24h

# --- Public URLs ---
# Institution web app (emails, links). CORS allows browser origins.
WEB_APP_URL=http://localhost:3000
# Optional: canonical API URL for docs / Railway (not read by Nest config today)
# RAIN_API_URL=https://your-api.up.railway.app

# --- Payments ---
PAYMENT_PROVIDER=monnify
# Fee added on top of wallet credit amount (₦)
MONNIFY_WALLET_FUNDING_FEE=100

# Monnify sandbox dashboard: https://sandbox.monnify.com
MONNIFY_API_KEY=MK_TEST_XXXXXX
MONNIFY_SECRET_KEY=SK_TEST_XXXXXX
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://sandbox.monnify.com
# Where Monnify sends the user after checkout
MONNIFY_WALLET_REDIRECT_URL=http://localhost:3000/wallet
# Disbursement source wallet (required for bank earnings payouts)
MONNIFY_WALLET_ACCOUNT_NUMBER=

# --- Monnify webhooks ---
# Dashboard → Webhook URLs → POST {RAIN_API_URL}/webhooks/monnify
# Enable Transaction completion + Disbursement (and Refund/settlement if listed)
MONNIFY_WEBHOOK_ALLOWED_IPS=35.242.133.146
# Production defaults to true; use false when testing sandbox from Railway/local
MONNIFY_WEBHOOK_ENFORCE_IP=false
# Sandbox: Monnify often omits monnify-signature — leave false or unset
# Live production: set true or rely on auto (required when not on sandbox URL)
MONNIFY_WEBHOOK_REQUIRE_SIGNATURE=false

# --- Outbound webhooks (institution endpoints) ---
WEBHOOK_DELIVERY_PROVIDER=http

# --- Email ---
EMAIL_PROVIDER=console
# EMAIL_FROM=Rain <noreply@rain.ng>
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# EMAIL_OPS_ADDRESS=ops@userain.co

# --- Earnings bank payout worker (optional) ---
# EARNINGS_BANK_WITHDRAW_MIN_DELAY_MINUTES=60
# EARNINGS_BANK_WITHDRAW_MAX_DELAY_MINUTES=120
# EARNINGS_BANK_WITHDRAW_WORKER_INTERVAL_MS=300000
# Local fast testing:
# EARNINGS_BANK_WITHDRAW_MIN_DELAY_MINUTES=0
# EARNINGS_BANK_WITHDRAW_MAX_DELAY_MINUTES=0
