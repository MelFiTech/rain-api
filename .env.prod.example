# Production template — copy to .env.prod and fill secrets (never commit .env.prod)
# Railway service: https://rain-api-production.up.railway.app

PORT=9090
NODE_ENV=production

DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

JWT_SECRET=
JWT_EXPIRES_IN=24h

RAIN_API_URL=https://rain-api-production.up.railway.app
WEB_APP_URL=https://your-institution-app.example
MONNIFY_WALLET_REDIRECT_URL=https://your-institution-app.example/wallet

PAYMENT_PROVIDER=monnify
MONNIFY_WALLET_FUNDING_FEE=100
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=
MONNIFY_BASE_URL=https://sandbox.monnify.com
MONNIFY_WALLET_ACCOUNT_NUMBER=

MONNIFY_WEBHOOK_ALLOWED_IPS=35.242.133.146
MONNIFY_WEBHOOK_ENFORCE_IP=false
MONNIFY_WEBHOOK_REQUIRE_SIGNATURE=false

WEBHOOK_DELIVERY_PROVIDER=http
EMAIL_PROVIDER=console

EARNINGS_BANK_WITHDRAW_MIN_DELAY_MINUTES=60
EARNINGS_BANK_WITHDRAW_MAX_DELAY_MINUTES=120
EARNINGS_BANK_WITHDRAW_WORKER_INTERVAL_MS=300000
